# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***

# Stripe Configuration
# STRIPE_MODE: Set to 'test' for development or 'live' for production
# If not set, defaults to 'test' in development and 'live' in production
STRIPE_MODE=test

# Stripe API Keys
# For development: Use sk_test_*** and pk_test_***
# For production (Vercel): Use sk_live_*** and pk_live_***
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_***

# Credit-pack price IDs (one-time payments). The app selects the *_TEST or
# *_LIVE variant based on STRIPE_MODE; a bare STRIPE_PRICE_ENTRY / _STANDARD is
# used as a fallback. Entry = $2.99 / 5 credits, Standard = $6.99 / 20 credits.
STRIPE_PRICE_ENTRY_TEST=price_***
STRIPE_PRICE_STANDARD_TEST=price_***
STRIPE_PRICE_ENTRY_LIVE=price_***
STRIPE_PRICE_STANDARD_LIVE=price_***

BASE_URL=http://localhost:3000
AUTH_SECRET=***
REPLICATE_API_TOKEN=r8_Vvt**********************************
# Initial credits for new users (default: 3, set higher for testing)
INITIAL_USER_CREDITS=50
# Development mode - unlimited credits (true/false)
DEV_UNLIMITED_CREDITS=true

DATABASE_URL=***
DATABASE_URL_UNPOOLED=***
